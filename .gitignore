.gitignore
# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# Node
node_modules/
dist/
build/
*.tsbuildinfo
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite
.vite/

# Python
__pycache__/
*.pyc
*.pyo
venv/
env/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Environment files
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
.env.staging.local
.envrc

# Logs
logs/
*.log

# Testing
coverage/
coverage-reports/

# Database
*.sqlite3
*.db

# Others
*.local
*.dev/
*.production/

# Exclude all dev.* directories and files
**/dev.*/

# Qodo
.qodo/
excel-pq-symbols/
.claude/
.opencode/
